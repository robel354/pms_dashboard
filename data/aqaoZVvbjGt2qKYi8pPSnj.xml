  <h:body>
    <input ref="/aqaoZVvbjGt2qKYi8pPSnj/extension_officer_id">
      <label>Extension Officer ID</label>
    </input>
    <input ref="/aqaoZVvbjGt2qKYi8pPSnj/date_time">
      <label>Enter a date and time</label>
    </input>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/submission_channel">
      <label>Submission channel</label>
      <itemset nodeset="instance('ju7yx68')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/complainant_area">
      <label>Which community or area is the complainant from?</label>
      <itemset nodeset="instance('jb8rp59')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input ref="/aqaoZVvbjGt2qKYi8pPSnj/complainant_area_other">
      <label>Please specify which area the complainant is from.</label>
    </input>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/project_involved">
      <label>Is the complainant involved with the project?</label>
      <itemset nodeset="instance('ox96r42')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/anonymous">
      <label>Is the submission anonymous?</label>
      <itemset nodeset="instance('aj7ee33')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input ref="/aqaoZVvbjGt2qKYi8pPSnj/complainant_name">
      <label>What is the complainant's name?</label>
    </input>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/complainant_communication">
      <label>What is the complainant's preferred form of communication</label>
      <itemset nodeset="instance('yo8jz87')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/complainant_meeting_place">
      <label>Where would the complainant prefer to meet to receive any updates on the grievance?</label>
      <itemset nodeset="instance('sc1dm92')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input ref="/aqaoZVvbjGt2qKYi8pPSnj/complainant_phone">
      <label>What is the complainant's phone number?</label>
    </input>
    <input ref="/aqaoZVvbjGt2qKYi8pPSnj/complainant_email">
      <label>What is the complainant's email adress?</label>
    </input>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/grievance_type">
      <label>What type of grievance is this?</label>
      <itemset nodeset="instance('ni9fh26')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input ref="/aqaoZVvbjGt2qKYi8pPSnj/grievance_type_other">
      <label>Please describe what other type of issue.</label>
    </input>
    <input appearance="multiline" ref="/aqaoZVvbjGt2qKYi8pPSnj/grievance_description">
      <label>Description of the grievance.</label>
    </input>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/grievance_urgency">
      <label>Is this grievance urgent?</label>
      <itemset nodeset="instance('bz5py53')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/immediate_action">
      <label>Was any immediate action taken?</label>
      <itemset nodeset="instance('st3eb67')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input appearance="multiline" ref="/aqaoZVvbjGt2qKYi8pPSnj/immediate_action_taken">
      <label>What immediate action was taken?</label>
    </input>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/onsite_resolution">
      <label>Was it resolved on site?</label>
      <itemset nodeset="instance('he9go74')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/grievance_severity">
      <label>What is the severity level of the grievance?</label>
      <itemset nodeset="instance('gq1xy11')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <input appearance="multiline" ref="/aqaoZVvbjGt2qKYi8pPSnj/extension_officer_observation">
      <label>Extension Officer Observations, if any.</label>
      <hint>Add any relevant observations or context based on your visit. Do not modify the grievance description.</hint>
    </input>
    <select1 ref="/aqaoZVvbjGt2qKYi8pPSnj/photo_possible">
      <label>If applicable, is it possible to take a photograph of the issue?</label>
      <itemset nodeset="instance('yk8qd87')/root/item">
        <value ref="name"/>
        <label ref="label"/>
      </itemset>
    </select1>
    <upload mediatype="image/*" ref="/aqaoZVvbjGt2qKYi8pPSnj/issue_photograph">
      <label>Please take a photograph of the issue.</label>
    </upload>
    <upload mediatype="image/*" ref="/aqaoZVvbjGt2qKYi8pPSnj/grievance_photo">
      <label>Please take a photograph of the grievance submitted through the drop box</label>
    </upload>
  </h:body>
