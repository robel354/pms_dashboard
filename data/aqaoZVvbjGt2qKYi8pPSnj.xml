      <bind nodeset="/aqaoZVvbjGt2qKYi8pPSnj/extension_officer_id" type="string" required="true()"/>
      <bind nodeset="/aqaoZVvbjGt2qKYi8pPSnj/date_time" type="dateTime" required="true()"/>
      <bind nodeset="/aqaoZVvbjGt2qKYi8pPSnj/submission_channel" type="string" required="true()"/>
      <bind nodeset="/aqaoZVvbjGt2qKYi8pPSnj/complainant_area" type="string" required="true()"/>
      <bind nodeset="/aqaoZVvbjGt2qKYi8pPSnj/complainant_area_other" type="string" relevant=" /aqaoZVvbjGt2qKYi8pPSnj/complainant_area  = 'other'" required="true()"/>
